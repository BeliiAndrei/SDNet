<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SDNet"
             x:Class="SDNet.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="ThemePageBackgroundColor">#F2F2F2</Color>
            <Color x:Key="ThemeSectionBackgroundColor">#E0E0E0</Color>
            <Color x:Key="ThemePrimaryTextColor">#0D0D0D</Color>
            <Color x:Key="ThemeSecondaryTextColor">#404040</Color>
            <Color x:Key="ThemeCardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="ThemeBorderColor">#C8C8C8</Color>
            <Color x:Key="ThemeAccentColor">#512BD4</Color>
            <Color x:Key="ThemeSwitchTrackColor">#DFD8F7</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
