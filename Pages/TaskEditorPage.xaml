<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:SDNet.PageModels"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="SDNet.Pages.TaskEditorPage"
             x:DataType="pageModels:TaskEditorPageModel"
             Title="Редактирование задачи">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Удалить"
                     Order="Primary"
                     Priority="0"
                     IconImageSource="{StaticResource IconDelete}"
                     IsEnabled="{Binding IsExistingTask}"
                     Command="{Binding DeleteCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutPadding}"
                             Spacing="{StaticResource LayoutSpacing}">
            <sf:SfTextInputLayout Hint="Тип задачи">
                <Picker ItemsSource="{Binding TaskTypes}"
                        SelectedItem="{Binding SelectedTaskType}" />
            </sf:SfTextInputLayout>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="№ запроса">
                    <Entry Text="{Binding UserQueryId}" Keyboard="Numeric" IsReadOnly="True" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1" Hint="Дата регистрации">
                    <DatePicker Date="{Binding DateReg}" IsEnabled="False" />
                </sf:SfTextInputLayout>
            </Grid>

            <sf:SfTextInputLayout Hint="Краткое описание">
                <Entry Text="{Binding ShortDescription}" />
            </sf:SfTextInputLayout>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="Приоритет">
                    <Picker ItemsSource="{Binding Priorities}"
                            SelectedItem="{Binding Priority}" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1" Hint="Состояние">
                    <Picker ItemsSource="{Binding States}"
                            SelectedItem="{Binding StateName}" />
                </sf:SfTextInputLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="Автор">
                    <Entry Text="{Binding UserFio}" IsReadOnly="True" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1" Hint="Подразделение">
                    <Picker ItemsSource="{Binding DepartmentOptions}"
                            SelectedItem="{Binding UserDepartName}" />
                </sf:SfTextInputLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="Тег">
                    <Entry Text="{Binding UserQueryTag}" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1" Hint="Тип запроса">
                    <Picker ItemsSource="{Binding QueryTypeOptions}"
                            SelectedItem="{Binding QueryTypeName}" />
                </sf:SfTextInputLayout>
            </Grid>

            <sf:SfTextInputLayout Hint="IT-проект">
                <Picker ItemsSource="{Binding ItProjectOptions}"
                        SelectedItem="{Binding ItProjectName}" />
            </sf:SfTextInputLayout>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="Срок закрытия">
                    <DatePicker Date="{Binding DateNeedClose}" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1"
                                      Hint="Дата закрытия"
                                      IsVisible="{Binding IsDateClosedVisible}">
                    <DatePicker Date="{Binding DateClosed}" />
                </sf:SfTextInputLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout Grid.Column="0" Hint="Исполнитель">
                    <Picker ItemsSource="{Binding PerformerOptions}"
                            SelectedItem="{Binding SelectedPerformer}" />
                </sf:SfTextInputLayout>
                <sf:SfTextInputLayout Grid.Column="1" Hint="Отдел исполнителя">
                    <Entry Text="{Binding PerformerDepartName}" IsReadOnly="True" />
                </sf:SfTextInputLayout>
            </Grid>

            <sf:SfTextInputLayout Hint="% выполнения">
                <Grid RowDefinitions="Auto,Auto">
                    <Slider Grid.Row="0"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding PerformPercent}" />
                    <Label Grid.Row="1"
                           HorizontalOptions="End"
                           Text="{Binding PerformPercent, StringFormat='{0:F0}%'}" />
                </Grid>
            </sf:SfTextInputLayout>

            <Border IsVisible="{Binding IsITTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля IT-задачи" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Система">
                        <Entry Text="{Binding ItSystemArea}" />
                    </sf:SfTextInputLayout>
                    <CheckBox IsChecked="{Binding ItRequiresDeployment}" />
                    <Label Text="Нужен деплой" Style="{StaticResource Caption1}" />
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsHardwareTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля оборудования" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Модель">
                        <Entry Text="{Binding HardwareModel}" />
                    </sf:SfTextInputLayout>
                    <sf:SfTextInputLayout Hint="Инвентарный номер">
                        <Entry Text="{Binding HardwareAssetNumber}" />
                    </sf:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsCommunicationTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля коммуникаций" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Канал">
                        <Entry Text="{Binding CommunicationChannel}" />
                    </sf:SfTextInputLayout>
                    <sf:SfTextInputLayout Hint="Контакт">
                        <Entry Text="{Binding CommunicationContact}" />
                    </sf:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsAccessTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля доступа" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Роль">
                        <Entry Text="{Binding AccessRole}" />
                    </sf:SfTextInputLayout>
                    <sf:SfTextInputLayout Hint="Ресурс">
                        <Entry Text="{Binding AccessResource}" />
                    </sf:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsSecurityTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля ИБ" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Уровень риска">
                        <Entry Text="{Binding SecurityRiskLevel}" />
                    </sf:SfTextInputLayout>
                    <CheckBox IsChecked="{Binding SecurityRequiresAudit}" />
                    <Label Text="Требуется аудит" Style="{StaticResource Caption1}" />
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding IsIntegrationTask}">
                <VerticalStackLayout Spacing="{StaticResource size120}">
                    <Label Text="Поля интеграции" Style="{StaticResource Body2Strong}" />
                    <sf:SfTextInputLayout Hint="Endpoint">
                        <Entry Text="{Binding IntegrationEndpoint}" />
                    </sf:SfTextInputLayout>
                    <sf:SfTextInputLayout Hint="Система">
                        <Entry Text="{Binding IntegrationSystem}" />
                    </sf:SfTextInputLayout>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="{StaticResource LayoutSpacing}"
                  Margin="0,10,0,0">
                <Button Grid.Column="0"
                        Text="Сохранить"
                        Command="{Binding SaveCommand}" />
                <Button Grid.Column="1"
                        Text="Отмена"
                        Command="{Binding CancelCommand}" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
